# ============================================================
#  EXAMPLE — Copy this file to .env and fill in your values.
#  This file IS safe to commit (no real secrets here).
# ============================================================

# ── Admin user ───────────────────────────────────────────────
VITE_ADMIN_NAME=Admin Owner
VITE_ADMIN_EMAIL=your-admin@email.com
VITE_ADMIN_PASSWORD=your-secure-password

# ── Payment ──────────────────────────────────────────────────
VITE_UPI_ID=your-upi-id@bank

# ── Employees ────────────────────────────────────────────────
# Define as many as you like with VITE_EMP{n}_NAME / _EMAIL / _PASSWORD.
# The seed scans n = 1..200 and loads every entry that has an email
# (gaps are allowed). Each becomes a cashier who can take orders.
# Emails MUST be unique. The shipped .env defines 50 employees.
VITE_EMP1_NAME=Employee One
VITE_EMP1_EMAIL=emp1@yourdomain.com
VITE_EMP1_PASSWORD=emp1-secure-password

VITE_EMP2_NAME=Employee Two
VITE_EMP2_EMAIL=emp2@yourdomain.com
VITE_EMP2_PASSWORD=emp2-secure-password

# VITE_EMP3_NAME=...
# VITE_EMP3_EMAIL=emp3@yourdomain.com
# VITE_EMP3_PASSWORD=...
